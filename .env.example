# ── Supabase ──────────────────────────────────────────────────────────────────
SUPABASE_URL=https://your-project-id.supabase.co
SUPABASE_SERVICE_KEY=your-service-role-key

# ── Auth ──────────────────────────────────────────────────────────────────────
JWT_SECRET=change-me-to-a-long-random-string

# ── App URL (REQUIRED in production) ─────────────────────────────────────────
# Must be your public domain — invite links are built from this.
# Example for Railway: https://yourapp.up.railway.app
BASE_URL=https://yourapp.up.railway.app

# ── Email provider (required for invite emails to send) ───────────────────────
# Configure either Resend or SMTP. Set EMAIL_PROVIDER to force one, or leave on auto.
EMAIL_PROVIDER=auto

# Resend example
RESEND_API_KEY=re_xxxxxxxxx
EMAIL_FROM=NodeRoute Systems <onboarding@yourdomain.com>

# SMTP example
# Gmail example: SMTP_HOST=smtp.gmail.com, SMTP_PORT=587, SMTP_SECURE=false
#   Use an App Password (not your account password) if 2FA is on.
# SendGrid example: SMTP_HOST=smtp.sendgrid.net, SMTP_USER=apikey, SMTP_PASS=<api-key>
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_SECURE=false
SMTP_USER=your-email@gmail.com
SMTP_PASS=your-app-password
EMAIL_FROM=NodeRoute Systems <your-email@gmail.com>

# ── OpenAI AI features ───────────────────────────────────────────────────────
# Required for AI walkthroughs, purchase order scanning, inventory health checks,
# reorder-message drafting, and demand forecasting.
OPENAI_API_KEY=sk-proj-your-openai-api-key
# Optional model overrides; leave unset unless you specifically want to change them.
# OPENAI_MODEL=gpt-4o-mini
# OPENAI_VISION_MODEL=gpt-4o

# ── Admin seed account ────────────────────────────────────────────────────────
ADMIN_EMAIL=admin@noderoutesystems.com
ADMIN_PASSWORD=Change-Me-On-First-Login!

# ── Optional ─────────────────────────────────────────────────────────────────
# PORT=3001
# GOOGLE_MAPS_KEY=your-google-maps-api-key
# CORS_ORIGIN=https://yourapp.up.railway.app
# FEATURE_UI_V2_DEFAULT=false

# ── Customer Portal Payments (Stripe) ────────────────────────────────────────
# Set PORTAL_PAYMENT_ENABLED=true and PORTAL_PAYMENT_PROVIDER=stripe to enable
# secure payment method saving, autopay, and checkout in the customer portal.
# PORTAL_PAYMENT_ENABLED=true
# PORTAL_PAYMENT_PROVIDER=stripe
# STRIPE_PUBLISHABLE_KEY=pk_live_or_test_xxx
# STRIPE_SECRET_KEY=sk_live_or_test_xxx
# STRIPE_WEBHOOK_SECRET=whsec_xxx
# PORTAL_PAYMENT_CURRENCY=usd
# PORTAL_PAYMENT_SUPPORT_EMAIL=support@noderoutesystems.com

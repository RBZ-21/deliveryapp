# Supabase
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_SERVICE_KEY=your-service-role-key

# App
PORT=3001
BASE_URL=https://noderoutesystems.com

# Admin account (used only when users.json is first created)
ADMIN_EMAIL=admin@noderoute.com
ADMIN_PASSWORD=change-me-in-production

# Google Maps
GOOGLE_MAPS_KEY=your-google-maps-api-key

# CORS (set to your domain in production)
CORS_ORIGIN=https://noderoutesystems.com

# SMTP (for emailing signed invoices — e.g. Gmail, SendGrid, or your mail host)
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_SECURE=false
SMTP_USER=your-email@gmail.com
SMTP_PASS=your-app-password
EMAIL_FROM=NodeRoute Invoices <invoices@noderoutesystems.com>

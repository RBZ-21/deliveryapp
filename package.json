{
  "name": "noderoute",
  "version": "1.0.0",
  "scripts": {
    "start": "node backend/server.js",
    "build:dashboard-v2": "npm --prefix frontend-v2 run build",
    "build:landing-v2": "npm --prefix landing-v2 run build",
    "build:driver-app": "npm --prefix driver-app run build",
    "build": "npm run build:dashboard-v2 && npm run build:landing-v2 && npm run build:driver-app",
    "test": "npm --prefix backend test && npm --prefix frontend-v2 test",
    "postinstall": "cd backend && npm install"
  },
  "dependencies": {
    "@sentry/node": "^10.51.0",
    "@sentry/react": "^10.51.0"
  }
}
